from fastapi import FastAPI
from fastapi.responses import HTMLResponse
import subprocess

app = FastAPI()


@app.get("/")
def root():
    return {"status": "running"}


@app.post("/run")
def run_pretace():

    p = subprocess.run(
        ["python", "pre_tace.py"],
        capture_output=True,
        text=True,
    )

    return {
        "stdout": p.stdout,
        "stderr": p.stderr,
        "returncode": p.returncode,
    }